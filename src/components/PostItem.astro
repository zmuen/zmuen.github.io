---
import { withBase } from "../utils/withBase";

interface Props {
  href: string;
  title: string;
  date: Date;
  category: string;
  description: string;
  image?: string;
}

const { href, title, date, category, description, image = "/images/post-default.svg" } = Astro.props;
---

<article class="media-item">
  <a class="media-thumb" href={withBase(href)}>
    <img src={withBase(image)} alt="" loading="lazy" />
  </a>
  <div class="media-copy">
    <p class="eyebrow">{category}</p>
    <h2><a href={withBase(href)}>{title}</a></h2>
    <p class="meta-note">
      {date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
    </p>
    <p>{description}</p>
  </div>
</article>
