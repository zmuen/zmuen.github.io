---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="CV" description="Curriculum vitae">
  <section class="page-header">
    <p class="eyebrow">Curriculum Vitae</p>
    <h1>Academic and professional record.</h1>
  </section>

    <section>
      <h2>Education</h2>
      <div class="cv-entry">
        <p class="meta-note">2024</p>
        <div>
          <h3>M.Sc., Computer Science (Machine Learning)</h3>
          <p>Georgia Institute of Technology</p>
        </div>
      </div>
      <div class="cv-entry">
        <p class="meta-note">2024</p>
        <div>
          <h3>MLA, Landscape Architecture</h3>
          <p>Harvard University</p>
        </div>
      </div>
      <div class="cv-entry">
        <p class="meta-note">2020</p>
        <div>
          <h3>B.Sc., Architecture</h3>
          <p>Karlsruhe Institute of Technology</p>
        </div>
      </div>
    </section>

    <div class="cv-grid">
    <section>
      <h2>Research</h2>
      <div class="cv-entry">
        <p class="meta-note">2026-Present</p>
        <div>
          <h3>Research Data Scientist (Geospatial Analytics), California Academy of Sciecnes</h3>
          <p>Geospatial integration with acoustic AI to study how fire shapes forest resilience.</p>
        </div>
      </div>
      <div class="cv-entry">
        <p class="meta-note">2024</p>
        <div>
          <h3>Research Associate, Bloomberg Center for Cities at Harvard Univeristy</h3>
          <p>Developed geosptaial studies on urban air quality monitoring network.</p>
        </div>
      </div>
    </section>

    <div class="cv-grid">
    <section>
      <h2>Professional</h2>
      <div class="cv-entry">
        <p class="meta-note">2025-Present</p>
        <div>
          <h3>Data Scientist, Ekotrope</h3>
          <p>Working across energy modeling, scenario modeling and data engineering.</p>
        </div>
      </div>
      <div class="cv-entry">
        <p class="meta-note">2023</p>
        <div>
          <h3>Planning Intern, HOK</h3>
          <p>Participated in a range of urban and landscape design projects spanning aviation, sports, and academic sectors.</p>
        </div>
      </div>
    </section>

    <section>
      <h2>Awards</h2>
      <div class="cv-entry">
        <p class="meta-note">2025</p>
        <div>
          <h3>Vectorworks Design Scholarship 2023</h3>
          <p>Project: Journey - A Regeneration Process of New Life</p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
