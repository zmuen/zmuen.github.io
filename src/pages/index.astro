---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectItem from "../components/ProjectItem.astro";
import { siteMeta } from "../data/site";
import { projects } from "../data/projects";
import { publications } from "../data/publications";

const latestPublications = [...publications].sort((a, b) => b.year - a.year).slice(0, 2);
---

<BaseLayout title="Home" description={siteMeta.bio}>
  <section class="hero">
    <p class="eyebrow">Research Profile</p>
    <h1>Observability, inference, and decision-making in partially observable systems</h1>
    <p class="lead">{siteMeta.bio}</p>
    <div class="link-row">
      {siteMeta.links.map((link) => (
        <a href={link.href} target="_blank" rel="noreferrer">
          {link.label}
        </a>
      ))}
    </div>
  </section>

  <section class="section-block">
    <div class="section-heading">
      <p class="eyebrow">Latest Publication</p>
      <h2>Publications</h2>
    </div>
    <div class="publication-list">
      {latestPublications.map((pub) => (
        <article class="publication-item">
          <p class="publication-citation">
            <span>{pub.authors.join(", ")}.</span>{" "}
            <span class="publication-title">"{pub.title}."</span>{" "}
            <em>{pub.venue}</em>, {pub.year}.{" "}
            {pub.status} {pub.type}.
          </p>
          {/* pub.abstract && <p>{pub.abstract}</p> */}
          {pub.link && <p><a href={pub.link}>View publication</a></p>}
        </article>
      ))}
    </div>
  </section>

  <section class="section-block">
    <div class="section-heading">
      <p class="eyebrow">Selected Projects</p>
      <h2>Models, measurements, and decision tools</h2>
    </div>
    <div class="stack-list">
      {projects.slice(0, 2).map((project) => <ProjectItem {...project} />)}
    </div>
  </section>

</BaseLayout>
